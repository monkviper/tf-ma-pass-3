{% liquid
  assign has_desktop = false
  assign has_mobile = false

  if section.settings.image_desktop != blank
    assign has_desktop = true
  endif

  if section.settings.image_mobile != blank
    assign has_mobile = true
  endif

  assign ratio = 1

  case section.settings.image_ratio
    when 'landscape'
      assign ratio = '16 / 9'
    when 'portrait'
      assign ratio = '4 / 5'
    when 'adapt'
      if has_desktop
        assign ratio = section.settings.image_desktop.aspect_ratio
      elsif has_mobile
        assign ratio = section.settings.image_mobile.aspect_ratio
      endif
  endcase

  if ratio == 0 or ratio == null
    assign ratio = 1
  endif

  assign alt_text = section.settings.image_alt
  if alt_text == blank and has_desktop
    assign alt_text = section.settings.image_desktop.alt
  elsif alt_text == blank and has_mobile
    assign alt_text = section.settings.image_mobile.alt
  endif

  assign widths = '375,550,750,1100,1500,1780,2000,2560,3840'
  assign sizes_val = '100vw'
%}

{% capture section_style %}
  --ratio: {{ ratio }};
  {% render 'spacing-style', settings: section.settings %}
  {% render 'border-override', settings: section.settings %}
{% endcapture %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {% if has_desktop or has_mobile %}
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="image-banner spacing-style border-style" style="{{ section_style }}">
    {% else %}
      <div class="image-banner spacing-style border-style" style="{{ section_style }}">
    {% endif %}

    {% if has_desktop and has_mobile %}
      <picture>
        <source
          media="(max-width: 749px)"
          srcset="{{ section.settings.image_mobile | image_url: width: section.settings.image_mobile.width }}"
        >
        {{
          section.settings.image_desktop
          | image_url: width: section.settings.image_desktop.width
          | image_tag:
            sizes: sizes_val,
            widths: widths,
            class: 'image-banner__image',
            loading: 'lazy',
            alt: alt_text
        }}
      </picture>
    {% elsif has_desktop %}
      {{
        section.settings.image_desktop
        | image_url: width: section.settings.image_desktop.width
        | image_tag:
          sizes: sizes_val,
          widths: widths,
          class: 'image-banner__image',
          loading: 'lazy',
          alt: alt_text
      }}
    {% elsif has_mobile %}
      {{
        section.settings.image_mobile
        | image_url: width: section.settings.image_mobile.width
        | image_tag:
          sizes: sizes_val,
          widths: widths,
          class: 'image-banner__image',
          loading: 'lazy',
          alt: alt_text
      }}
    {% endif %}

    {% if section.settings.link != blank %}
      </a>
    {% else %}
      </div>
    {% endif %}
  {% else %}
    <div class="image-banner spacing-style border-style" style="{{ section_style }}">
      <div class="image-banner__placeholder">
        {{ 'detailed-apparel-1' | placeholder_svg_tag: 'image-banner__image' }}
      </div>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .image-banner {
    display: block;
    position: relative;
    overflow: hidden;
  }

  .image-banner__image {
    display: block;
    width: 100%;
    object-fit: cover;
    aspect-ratio: var(--ratio);
  }

  .image-banner__placeholder {
    aspect-ratio: var(--ratio);
    overflow: hidden;
  }

  .image-banner__placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.image_banner",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "t:settings.desktop_image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:settings.mobile_image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "t:settings.image_alt"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:settings.aspect_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ section.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ section.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.image_banner",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
